{
  "version": 1,
  "_guide": {
    "purpose": "桌宠情景对话词库。可用其他 AI 增删 speeches / variants，并扩展 when 条件。",
    "fields": {
      "patterns": "字符串默认忽略大小写；或 { pattern, flags }。匹配应用名+窗口标题，或 OCR 文本。",
      "when": {
        "timeOfDay": "morning(5-11) | noon(11-14) | afternoon(14-18) | evening(18-22) | night(22-5)",
        "hours": "0-23 的小时列表",
        "hourRanges": "[[start,end],...]，可跨午夜如 [22,5]",
        "weekdays": "0=周日 … 6=周六",
        "weekend": "true 表示周六日",
        "weekday": "true 表示周一到周五",
        "months": "1-12"
      },
      "variants": "同情景下按 when 优先选用的台词组；都不匹配则用 speeches",
      "placeholders": "change.appNamed 可用 {name} 插入应用名"
    },
    "tip": "更具体的规则请放在数组更前面（先匹配先生效）。",
    "agentLimits": "完成态优先用 Cursor Hooks（stop）推送；请求态仍可能靠 OCR（Needs attention 等）。没有官方 IDE Agent 查询接口，无法做到 100% 准确。"
  },
